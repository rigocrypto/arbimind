# Ethereum Configuration
ETHEREUM_RPC_URL=https://eth-mainnet.alchemyapi.io/v2/YOUR_KEY
PRIVATE_KEY=your_execution_wallet_private_key
WALLET_ADDRESS=optional_wallet_address_for_keyless_log_only
TREASURY_ADDRESS=your_treasury_wallet_address

# Network (mainnet | testnet)
NETWORK=mainnet

# EVM chain selection (arbitrum | polygon | ethereum)
EVM_CHAIN=arbitrum

# Testnet RPCs
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
WORLDCHAIN_SEPOLIA_RPC_URL=https://worldchain-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
SOLANA_RPC_URL=https://api.devnet.solana.com

# Polygon RPC (set to Amoy for testnet, mainnet for production)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
# Alternative (Infura Amoy)
# POLYGON_RPC_URL=https://polygon-amoy.infura.io/v3/YOUR_INFURA_PROJECT_ID

# DexScreener chain filter
DEXSCREENER_CHAIN_ID=arbitrum:sepolia

# Bot Configuration
# MIN_PROFIT_ETH is a loose sanity filter (default 0.0001 ETH).
# The real profit floor is MIN_PROFIT_USD in Trading Guards below.
MIN_PROFIT_ETH=0.0001
MAX_GAS_GWEI=50
MIN_PROFIT_THRESHOLD=0.005
SCAN_INTERVAL_MS=200

# Contract Configuration
ARB_EXECUTOR_ADDRESS=deployed_contract_address

# Private Relay Configuration (Optional)
PRIVATE_RELAY_URL=your_private_relay_url

# Logging Configuration
LOG_LEVEL=info

# Risk Management
MAX_SLIPPAGE_PERCENT=1.0
MAX_GAS_PRICE_GWEI=100
MIN_LIQUIDITY_ETH=10

# Trading Guards (hard limits before live execution)
MAX_TRADE_SIZE_ETH=0.10
MIN_PROFIT_USD=1.00
MAX_GAS_USD=2.00

# AI Scoring (optional)
# Points to backend /api/ai/predict-arb endpoint
AI_PREDICT_URL=https://arbimind-production.up.railway.app/api/ai/predict-arb
AI_MIN_SUCCESS_PROB=0.7
AI_MIN_EXPECTED_PROFIT_PCT=0.5
AI_LOG_URL=https://arbimind-production.up.railway.app/api/admin/ai-dashboard/predictions
AI_SERVICE_KEY=your-service-key
AI_MODEL_TAG=arb-model-v1
AI_PREDICTION_HORIZON_SEC=900

# Etherscan API (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key

# EVM swap aggregator (0x API — https://dashboard.0x.org/apps)
# EVM_SWAP_API_KEY=

# Sepolia Testnet (for testing)
SEPOLIA_RPC_URL=https://eth-sepolia.alchemyapi.io/v2/YOUR_KEY

# UI / WalletConnect (packages/ui/.env.local or Vercel)
# Get free at https://cloud.walletconnect.com - required for wallet connect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# UI / Balance Guard - min balance to trade (toast warning if below)
# 0.05 ETH + ~20 USDC (~$20) for gas-safe trades
NEXT_PUBLIC_MIN_TRADE_ETH=0.05
NEXT_PUBLIC_MIN_TRADE_USDC=20

# Deployment: UI → Backend (Vercel env)
# Must end with /api - used by useArbiApi.ts
NEXT_PUBLIC_API_URL=https://arbimind-production.up.railway.app/api

# Deployment: Backend CORS (Railway env)
FRONTEND_URL=https://arbimind.vercel.app

# Monetization / Activation gate (Backend)
# Set a long random secret for admin-only payment confirmation endpoint
ADMIN_SECRET=replace_with_long_random_secret
# Wallet that receives manual USDC subscription payments
USDC_PAYMENT_ADDRESS=0xYourUsdcTreasuryWallet
# When true, /api/engine/start requires paid + bot_active activation state
REQUIRE_PAID_ACTIVATION=false

# Sentry (optional)
# Backend (Railway):
# SENTRY_DSN=https://your-public-key@o0.ingest.sentry.io/project-id
# SENTRY_TRACES_SAMPLE_RATE=0.1
# UI (Vercel):
# NEXT_PUBLIC_SENTRY_DSN=https://your-public-key@o0.ingest.sentry.io/project-id

# Solana Bot Configuration
SOLANA_WATCHED_POOLS=4wTV1YmiEkRvAtNtsSGPtUrqRYQMe5SKy2uB4pT8Az4D
SOLANA_PUMP_FUN_PROGRAM=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
SOLANA_SCAN_INTERVAL_SEC=10
SOLANA_TRADING_ENABLED=false
SOLANA_LOG_ONLY=true
SOLANA_CANARY_MODE=true
SOLANA_MAX_NOTIONAL_USD=5
SOLANA_MIN_EXPECTED_PROFIT_USD=0.10
SOLANA_MAX_DAILY_LOSS_USD=25
SOLANA_MAX_SLIPPAGE_BPS=50
# Comma-separated Jupiter AMM labels or ammKeys allowed for Solana execution
# Empty = allow all; exact-match against ammLabel or ammKey from Jupiter quotes
SOLANA_AMM_ALLOWLIST=Raydium CLMM,Whirlpool
# Comma-separated template keys: <AMM label>|<accountFingerprint>
# Example: Whirlpool|df07c33cb3512aa3,Whirlpool|c20b8f45e113a524
SOLANA_TEMPLATE_DENYLIST=
# Use a paid provider for live trading and set both to the same mainnet endpoint.
SOLANA_RPC_URL_MAINNET_BETA=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_PRIVATE_KEY_BASE58=
# Jupiter API endpoint. Default: v6 (deprecated). Recommended: lite-api v1.
# JUPITER_BASE_URL=https://lite-api.jup.ag/swap/v1
# Transaction format: true = legacy, false = versioned (v0). Default: true.
# Set to false if Jupiter routes fail with 0x1788 on legacy mode.
# SOLANA_LEGACY_TX=true
# Allow multi-hop (2+ leg) Jupiter routes. Default: false (single-leg only).
# SOLANA_ALLOW_MULTIHOP=false

# Venue Risk Policy — controls execution gating based on venue risk tier.
# Comma-separated risk tiers. Venues in deny tiers are hard-blocked.
# SOLANA_RISK_DENY_TIERS=critical
# Venues in canary tiers are capped to canary notional.
# SOLANA_RISK_CANARY_TIERS=high
# Max notional USD for canary-tier venues. Default: 1.
# SOLANA_RISK_CANARY_MAX_USD=1
# Additional min-edge bps penalty for medium-risk venues. Default: 15.
# SOLANA_RISK_EDGE_BUMP_BPS=15

# Alerts Configuration
ALERT_MIN_CONFIDENCE=0.8
ALERT_TELEGRAM_TOKEN=your_telegram_bot_token
ALERT_TELEGRAM_CHAT_ID=your_telegram_chat_id
ALERT_DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
# Optional additional outbound hosts for alert webhooks (comma or space separated)
# ALERT_WEBHOOK_ALLOWLIST=discord.com,discordapp.com
ALERT_TWITTER_BEARER_TOKEN=your_twitter_api_bearer_token
ALERT_REDDIT_CLIENT_ID=your_reddit_client_id
ALERT_REDDIT_SECRET=your_reddit_client_secret
ALERT_REDDIT_USER_AGENT=ArbiMind/1.0
ALERT_REDDIT_SUBREDDIT=test

# Bot Canary Mode (optional, recommended for first live rollout)
CANARY_ENABLED=false
CANARY_NOTIONAL_ETH=0.01
CANARY_MAX_DAILY_LOSS_ETH=0.005

# Keyless LOG_ONLY option (bot service)
# If LOG_ONLY/BOT_LOG_ONLY=true and PRIVATE_KEY is omitted, set WALLET_ADDRESS for identity-only logs/telemetry.
