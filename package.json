{
  "name": "arbimind",
  "version": "1.0.0",
  "packageManager": "pnpm@10.27.0",
  "description": "The brain of on-chain arbitrage - Professional MEV/searcher system",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@arbimind/ui",
    "dev:ui": "npm run dev --workspace=@arbimind/ui",
    "dev:bot": "npm run dev --workspace=@arbimind/bot",
    "start": "npm run build --workspace=@arbimind/bot && npm run start --workspace=@arbimind/bot",
    "bot:canary": "pnpm --filter @arbimind/bot canary",
    "build": "pnpm -r --filter @arbimind/ui build",
    "build:all": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "pnpm run lint:ui",
    "lint:ui": "pnpm --filter @arbimind/ui lint",
    "lint:contracts": "pnpm --filter @arbimind/contracts lint",
    "lint:ts": "pnpm --filter @arbimind/backend lint && pnpm --filter @arbimind/bot lint",
    "typecheck": "pnpm run typecheck --workspace=@arbimind/backend && pnpm run typecheck --workspace=@arbimind/bot && pnpm run type-check --workspace=@arbimind/ui",
    "clean": "npm run clean --workspaces",
    "setup": "pnpm install",
    "smoke:deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke-post-deploy.ps1",
    "smoke:all": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke-post-deploy.ps1",
    "smoke:analytics": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke-post-deploy.ps1 -OnlyAnalytics",
    "smoke:ui:runtime": "pnpm --filter @arbimind/ui smoke:runtime:live"
  },
  "devDependencies": {
    "next": "16.2.3",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "arbitrage",
    "mev",
    "defi",
    "ethereum",
    "dex",
    "flash-loans",
    "trading"
  ],
  "author": "ArbiMind Team",
  "license": "MIT",
  "//overrideNotes": {
    "elliptic": "Low-severity, no upstream fix (patched: <0.0.0). Pulled by @toruslabs/eccrypto + @walletconnect/utils. Replace when upstream patches.",
    "defu": "GHSA-737v-mqg7-c878 prototype pollution. Override from 6.1.4 via h3 > unstorage chain."
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.1",
      "lodash-es": ">=4.18.1",
      "tar": "7.5.11",
      "glob": ">=10.5.0",
      "test-exclude@6.0.0>glob": "7.2.3",
      "preact": ">=10.28.2",
      "hono": "4.12.14",
      "follow-redirects": "1.16.0",
      "h3": "1.15.9",
      "qs": "6.14.2",
      "rollup": "4.59.0",
      "underscore": "1.13.8",
      "flatted": "3.4.2",
      "socket.io-parser": "4.2.6",
      "@isaacs/brace-expansion": "5.0.5",
      "minimatch@3>brace-expansion": "1.1.13",
      "minimatch@9>brace-expansion": "5.0.5",
      "minimatch@10>brace-expansion": "5.0.5",
      "brace-expansion": "5.0.5",
      "handlebars": "4.7.9",
      "elliptic": "6.6.1",
      "defu": "6.1.6",
      "express>path-to-regexp": "0.1.13",
      "diff": ">=4.0.4",
      "ox": "^0.12.0",
      "@solana/web3.js>bn.js": "5.2.3",
      "esbuild": ">=0.25.0",
      "@eslint/config-array": "^0.23.0",
      "eslint>minimatch": "3.1.4"
    }
  },
  "dependencies": {
    "protobufjs": "7.5.5"
  }
}
