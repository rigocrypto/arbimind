{
  "name": "@arbimind/bot",
  "version": "1.0.0",
  "description": "ArbiMind arbitrage bot - Off-chain opportunity detection and execution",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build --workspace=@arbimind/bot || npm run build"
  },
  "deploy": {
    "startCommand": "npm run build --workspace=@arbimind/bot && npm run start --workspace=@arbimind/bot"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "canary": "tsx src/canary.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ai": "tsx src/test-ai.ts",
    "predictor": "tsx src/run-predictor.ts",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tensorflow/tfjs-node": "^4.22.0",
    "axios": "^1.14.0",
    "big.js": "^7.0.1",
    "decimal.js": "^10.4.3",
    "dotenv": "^17.3.1",
    "ethers": "^6.8.1",
    "lodash": "^4.18.1",
    "ml-matrix": "^6.10.4",
    "ml-regression": "^6.3.0",
    "natural": "^6.10.4",
    "node-cron": "^3.0.3",
    "sentiment": "^5.0.2",
    "technicalindicators": "^3.1.0",
    "viem": "^2.21.0",
    "winston": "^3.11.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^8.57.1",
    "happy-dom": "^20.8.8",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "tsx": "^4.6.2",
    "typescript": "5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "arbitrage",
    "mev",
    "defi",
    "ethereum",
    "bot",
    "trading"
  ],
  "author": "ArbiMind Team",
  "license": "MIT"
}
