# ============================================================
# ArbiMind UI — Production Environment Variables (Vercel)
# ============================================================
# Copy relevant values to the Vercel dashboard (Settings → Environment Variables).
# Only NEXT_PUBLIC_* vars are exposed to the browser bundle.

# ── Required ─────────────────────────────────────────────────
# Backend API base URL (Express service on Railway).
# Must point to the BACKEND, not the bot service.
#   ✅  https://backend-production-0932.up.railway.app/api
#   ❌  https://arbimind-production.up.railway.app/api   ← this is the EVM bot
NEXT_PUBLIC_API_URL=https://backend-production-0932.up.railway.app/api

# Master switch — set to "true" to enable live API calls.
# When false, the UI uses built-in mock data.
NEXT_PUBLIC_ENABLE_API=true

# ── Wallet / Chain ───────────────────────────────────────────
# WalletConnect project ID (public, browser-safe).
NEXT_PUBLIC_WC_PROJECT_ID=4e6c19a060a6c5bfc0f5d7eadf905bb9

# Solana cluster. Must match the RPC URL below.
#   devnet | testnet | mainnet-beta
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
# NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# Solana RPC — use a public endpoint or a RESTRICTED-key URL.
# API keys in the URL are stripped client-side (SolanaProvider.tsx)
# but still appear in the Vercel build output. Prefer keyless URLs.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Solana MVP arb account (display-only in devnet funding panel).
# NEXT_PUBLIC_SOLANA_ARB_ACCOUNT=

# ── Feature Flags ────────────────────────────────────────────
# Public metrics/strategies endpoints. Set "true" only when the
# backend exposes GET /api/metrics and GET /api/strategies.
# When false (default), the UI shows mock data.
NEXT_PUBLIC_PUBLIC_METRICS=false

# Simulated-engine UI controls (start/stop/scan buttons).
# When false (default), the panel is read-only.
# NEXT_PUBLIC_SIM_ENGINE_UI=false

# ── EVM RPC Overrides (optional) ─────────────────────────────
# These override wagmi's default public RPCs. Only set if you
# need a specific provider. Use RESTRICTED keys — these are
# embedded in the browser bundle.
# NEXT_PUBLIC_ETHEREUM_RPC_URL=
# NEXT_PUBLIC_ARBITRUM_RPC_URL=
# NEXT_PUBLIC_OPTIMISM_RPC_URL=
# NEXT_PUBLIC_BASE_RPC_URL=
# NEXT_PUBLIC_POLYGON_RPC_URL=

# ── UI Cosmetics (optional) ─────────────────────────────────
# Pro variant layout: header-center | sidebar | off
# NEXT_PUBLIC_PRO_VARIANT=header-center

# Minimum trade thresholds shown in wallet page.
# NEXT_PUBLIC_MIN_TRADE_ETH=0.05
# NEXT_PUBLIC_MIN_TRADE_USDC=20

# Trusted wallet-connect hosts (comma-separated).
# NEXT_PUBLIC_WALLET_TRUSTED_HOSTS=arbimind.vercel.app
# NEXT_PUBLIC_CANONICAL_APP_URL=https://arbimind.vercel.app

# ── Server-side only (not NEXT_PUBLIC_) ──────────────────────
# Admin API key (used by server components / API routes).
# ADMIN_API_KEY=

# CSP report-only mode (set "false" to enforce).
# CSP_REPORT_ONLY=true

# Treasury / execution addresses (server-side display).
# TREASURY_ADDRESS=
# EXECUTION_ADDRESS=

# Allowed frontend origins for CORS / CSP (comma-separated).
# FRONTEND_URL=https://arbimind.vercel.app

# ── Do NOT set these ─────────────────────────────────────────
# NEXT_PUBLIC_VITE_DEV_SERVER_HOST  — not used by Next.js
# NEXT_PUBLIC_BOT_URL               — frontend should not talk to bot directly
# Any NEXT_PUBLIC_*_RPC_URL with unrotated/unrestricted API keys
